{
  "name": "video-script",
  "version": "0.1.0",
  "description": "AI-powered video generation CLI tool for tech tutorials",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "video-script": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src/"
  },
  "keywords": [
    "video",
    "ai",
    "cli",
    "tutorial",
    "generation"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xmaxbu/video-script.git"
  },
  "bugs": {
    "url": "https://github.com/0xmaxbu/video-script/issues"
  },
  "homepage": "https://github.com/0xmaxbu/video-script#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
