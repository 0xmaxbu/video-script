{
  "name": "video-script",
  "version": "0.1.0",
  "description": "AI-powered video generation CLI tool for tech tutorials",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "video-script": "./dist/cli/index.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "mastra dev -d src/mastra",
    "dev:cli": "tsx watch src/cli/index.ts",
    "studio": "npm run dev --workspace=@video-script/studio",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src/"
  },
  "keywords": [
    "video",
    "ai",
    "cli",
    "tutorial",
    "generation"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xmaxbu/video-script.git"
  },
  "bugs": {
    "url": "https://github.com/0xmaxbu/video-script/issues"
  },
  "homepage": "https://github.com/0xmaxbu/video-script#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@mastra/core": "^1.13.2",
    "@mozilla/readability": "^0.6.0",
    "@remotion/transitions": "4.0.436",
    "@video-script/renderer": "file:packages/renderer",
    "@video-script/types": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "inquirer": "^13.3.0",
    "linkedom": "^0.18.12",
    "ora": "^9.3.0",
    "pinyin": "^4.0.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^4.0.2",
    "turndown": "^7.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "node-loader": "^2.1.0",
    "null-loader": "^4.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
