{
  "name": "@video-script/renderer",
  "version": "0.1.0",
  "description": "Standalone Remotion-based video renderer CLI for video-script",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "video-script-render": "./bin/video-script-render.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
