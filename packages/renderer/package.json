  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@video-script/types": "workspace:*",
    "@remotion/bundler": "4.0.436",
    "@remotion/cli": "4.0.436",
    "@remotion/renderer": "4.0.436",
    "@remotion/studio": "4.0.436",
    "@remotion/studio-server": "4.0.436",
    "commander": "^14.0.3",
    "pinyin": "^3.0.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "bin"
