    {
      "id": "scene-003",
      "type": "code",
      "title": "Code Example: NoInfer",
      "narration": "Here is a practical example showing how NoInfer prevents unintended inference. The function signature uses NoInfer to ensure the default value type is inferred from the first argument only.",
      "duration": 15,
      "visualLayers": [
        {
          "id": "code-snippet",
          "type": "code",
          "content": "function createLogger<T>(options: { level: T; defaultLevel: NoInfer<T> }) {\n  return options;\n}\n\nconst logger = createLogger({\n  level: 'debug',\n  defaultLevel: 'info', // TypeScript error: 'info' not assignable to 'debug'\n});",
          "position": {
