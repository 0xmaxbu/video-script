      "id": "scene-002",
      "type": "feature",
      "title": "NoInfer Utility Type",
      "narration": "TypeScript 5.4 introduces the NoInfer utility type, which prevents TypeScript from inferring a generic type parameter from a specific usage site. This is especially useful in complex generic functions.",
      "duration": 20,
      "visualLayers": [
        {
          "id": "docs-screenshot",
          "type": "screenshot",
